# Clean URLs, security, performance

ErrorDocument 404 /404.php
ErrorDocument 410 /404.php

Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
RewriteEngine On

# Force HTTPS and non-www canonical host
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:\d+)?$ [NC]
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.dbbetonline\.ru$ [NC]
RewriteRule ^ https://dbbetonline.ru%{REQUEST_URI} [L,R=301]

# Remove duplicate slashes in the requested path
RewriteCond %{THE_REQUEST} \s//+ [OR]
RewriteCond %{REQUEST_URI} ^(.*/)//+(.*)$
RewriteRule .* %1/%2 [R=301,L]


# Remove explicit PHP filenames from public URLs before real-file serving
RewriteCond %{THE_REQUEST} \s/+index\.php(?:[?\s]|$) [NC]
RewriteRule ^index\.php$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+ru\.php(?:[?\s]|$) [NC]
RewriteRule ^ru\.php$ / [R=301,L]


RewriteCond %{THE_REQUEST} \s/+en\.php(?:[?\s]|$) [NC]
RewriteRule ^en\.php$ /en [R=301,L]
RewriteCond %{THE_REQUEST} \s/+uz\.php(?:[?\s]|$) [NC]
RewriteRule ^uz\.php$ /uz [R=301,L]
RewriteCond %{THE_REQUEST} \s/+tr\.php(?:[?\s]|$) [NC]
RewriteRule ^tr\.php$ /tr [R=301,L]
RewriteCond %{THE_REQUEST} \s/+kz\.php(?:[?\s]|$) [NC]
RewriteRule ^kz\.php$ /kz [R=301,L]
RewriteCond %{THE_REQUEST} \s/+pt\.php(?:[?\s]|$) [NC]
RewriteRule ^pt\.php$ /pt [R=301,L]
RewriteCond %{THE_REQUEST} \s/+bd\.php(?:[?\s]|$) [NC]
RewriteRule ^bd\.php$ /bd [R=301,L]
RewriteCond %{THE_REQUEST} \s/+id\.php(?:[?\s]|$) [NC]
RewriteRule ^id\.php$ /id [R=301,L]

RewriteRule ^ru/index\.php$ / [R=301,L,NC]
RewriteRule ^(en|uz|tr|kz|pt|bd|id)/index\.php$ /$1 [R=301,L,NC]

# Block any other direct PHP file access not explicitly redirected above
RewriteCond %{THE_REQUEST} \s/+[^?\s]+\.php(?:[?\s]|$) [NC]
RewriteRule ^.+\.php$ - [G,L]

# Root-language alias
RewriteRule ^ru/?$ / [R=301,L]

# Broad language aliases
RewriteRule ^kk/?$ /kz [R=301,L]
RewriteRule ^bn/?$ /bd [R=301,L]

# Normalize trailing slashes on clean public URLs
RewriteRule ^(en|uz|tr|kz|pt|bd|id)/$ /$1 [R=301,L]

# Serve real files and folders directly after canonical redirects
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Pretty URLs -> PHP files
RewriteRule ^$ index.php [L]
RewriteRule ^en$ en.php [L]
RewriteRule ^uz$ uz.php [L]
RewriteRule ^tr$ tr.php [L]
RewriteRule ^kz$ kz.php [L]
RewriteRule ^pt$ pt.php [L]
RewriteRule ^bd$ bd.php [L]
RewriteRule ^id$ id.php [L]

# Only the main pages are public; all other non-file URLs are permanently gone
RewriteRule ^.+$ - [G,L]
</IfModule>

# Basic security: block hidden/config files
<FilesMatch "(^\.|\.ini$|\.log$|\.env$|composer\.(json|lock)$)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/css text/html text/javascript application/javascript application/json application/xml text/xml image/svg+xml
</IfModule>

# Browser caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>


# SEO audit fix: protect include/link-management files
# Direct HTTP access is denied; PHP require/include still works, so link variables stay editable in puddin.php.
<FilesMatch "^(puddin|request\-context)\.php$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>
