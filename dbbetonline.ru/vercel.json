{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "redirects": [
    { "source": "/ru/?", "destination": "/", "permanent": true },
    { "source": "/kk/?", "destination": "/kz", "permanent": true },
    { "source": "/bn/?", "destination": "/bd", "permanent": true },
    { "source": "/index.php", "destination": "/", "permanent": true },
    { "source": "/ru/index.php", "destination": "/", "permanent": true },
    { "source": "/:lang(en|uz|tr|kz|pt|bd|id)/index.php", "destination": "/:lang", "permanent": true },
    { "source": "/:page(en|uz|tr|kz|pt|bd|id)\\.php", "destination": "/:page", "permanent": true }
  ],
  "rewrites": [
    { "source": "/(en|uz|tr|kz|pt|bd|id)", "destination": "/api/$1.php" },
    { "source": "/", "destination": "/api/index.php" },
    { "source": "/(.*)", "destination": "/api/404.php" }
  ]
}
